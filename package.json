{
  "name": "tellme",
  "version": "0.1.0",
  "description": "Local TTS for coding agents — read AI responses aloud. Supports Pi, Claude Code, and OpenCode.",
  "type": "module",
  "keywords": [
    "pi-package",
    "tts",
    "text-to-speech",
    "kokoro",
    "piper",
    "coding-agent"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./src/integrations/pi/index.ts"
    ]
  },
  "bin": {
    "tellme": "./bin/tellme.js"
  },
  "scripts": {
    "build": "echo 'nothing to build — loaded via jiti'",
    "clean": "echo 'nothing to clean'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "sherpa-onnx-node": "^1.12.38"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.4"
  }
}
